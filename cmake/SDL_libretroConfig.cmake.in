@PACKAGE_INIT@
include(CMakeFindDependencyMacro)
find_dependency(SDL3)
include("${CMAKE_CURRENT_LIST_DIR}/SDL_libretroTargets.cmake")

# SDL3 is attached here rather than baked into the export because the
# project's own build may vendor SDL3 in-tree, which cannot be exported.
set_property(TARGET SDL_libretro::SDL_libretro APPEND PROPERTY
    INTERFACE_LINK_LIBRARIES SDL3::SDL3)
